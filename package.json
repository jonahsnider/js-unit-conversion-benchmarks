		"@lukeed/ms": "2.0.2",
		"byte-size": "9.0.1",
		"convert": "7.0.0",
		"convert-units": "3.0.0-beta.8",
		"dayjs": "1.11.20",
		"js-quantities": "1.8.0",
		"luxon": "3.7.2",
		"moment": "2.30.1",
		"ms": "2.1.3",
		"prettier": "3.8.3",
		"safe-units": "2.0.1",
		"simple-units": "1.1.5",
