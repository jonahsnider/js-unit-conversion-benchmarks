{
	"name": "@jonahsnider/js-unit-conversion-benchmarks",
	"version": "1.0.0",
	"private": true,
	"description": "Some benchmarks of community-made libraries for converting units.",
	"license": "MIT",
	"author": {
		"name": "Jonah Snider",
		"email": "jonah@jonah.pw",
		"url": "https://jonahsnider.com"
	},
	"type": "module",
	"scripts": {
